# =============================================================================
# ModularMind V2 — Environment Configuration
# =============================================================================
# Copy to .env and fill in values

# --- Core ---
SECRET_KEY=change-me-to-random-string
ENVIRONMENT=development  # development | production

# --- Database ---
DB_USER=modularmind
DB_PASSWORD=modularmind
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@db:5432/modularmind

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333

# --- Ollama ---
OLLAMA_BASE_URL=http://ollama:11434

# --- LLM (set in dashboard or here as fallback) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Platform Sync (optional — leave empty to disable) ---
PLATFORM_URL=
ENGINE_API_KEY=
SYNC_INTERVAL_SECONDS=300

# --- Platform (only for platform deployment) ---
# NEXTAUTH_SECRET=change-me
# NEXTAUTH_URL=https://your-platform-domain.com

# --- Auth ---
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
