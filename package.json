{
  "name": "modularmind-v2",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:chat": "turbo dev --filter=@modularmind/chat",
    "dev:ops": "turbo dev --filter=@modularmind/ops",
    "build:chat": "turbo build --filter=@modularmind/chat",
    "build:ops": "turbo build --filter=@modularmind/ops",
    "dev:platform": "turbo dev --filter=@modularmind/platform",
    "build:platform": "turbo build --filter=@modularmind/platform",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "turbo": "^2.3.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.15.0"
}
