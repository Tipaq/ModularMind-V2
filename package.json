{
  "name": "modularmind-v2",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:chat": "turbo dev --filter=@modularmind/chat",
    "dev:ops": "turbo dev --filter=@modularmind/ops",
    "build:chat": "turbo build --filter=@modularmind/chat",
    "build:ops": "turbo build --filter=@modularmind/ops",
    "dev:platform": "turbo dev --filter=@modularmind/platform",
    "build:platform": "turbo build --filter=@modularmind/platform",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@next/eslint-plugin-next": "^16.1.6",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "turbo": "^2.3.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.31.0"
}
