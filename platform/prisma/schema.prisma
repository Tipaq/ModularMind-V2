generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  role         String   @default("admin") // owner | admin
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Client {
  id        String   @id @default(cuid())
  name      String
  engines   Engine[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Engine {
  id               String    @id @default(cuid())
  name             String
  url              String
  apiKey           String    @unique
  clientId         String
  client           Client    @relation(fields: [clientId], references: [id])
  lastSeen         DateTime?
  version          Int       @default(0)
  status           String    @default("registered") // registered | synced | offline
  deploymentConfig Json?     // Infrastructure config for client install
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Agent {
  id          String   @id @default(cuid())
  name        String
  description String
  model       String
  provider    String
  config      Json     @default("{}")
  version     Int      @default(1)
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Graph {
  id          String   @id @default(cuid())
  name        String
  description String
  nodes       Json     @default("[]")
  edges       Json     @default("[]")
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Automation {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  enabled     Boolean  @default(false)
  config      Json     @default("{}")
  version     Int      @default(1)
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// =============================================================================
// Mini-Apps — Agent-created web applications
// =============================================================================

model MiniApp {
  id            String   @id @default(cuid())
  name          String
  slug          String
  description   String   @default("")
  icon          String?
  entryFile     String   @default("index.html")
  version       Int      @default(1)
  isActive      Boolean  @default(true)

  // Ownership & Scope (same model as RAG collections)
  scope         String   @default("PERSONAL") // GLOBAL | GROUP | PERSONAL
  allowedGroups String[] @default([])
  ownerUserId   String?
  agentId       String?

  // Relations
  files         MiniAppFile[]
  storage       MiniAppStorage[]
  snapshots     MiniAppSnapshot[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([agentId, slug])
  @@index([scope])
  @@index([ownerUserId])
}

model MiniAppFile {
  id          String   @id @default(cuid())
  appId       String
  app         MiniApp  @relation(fields: [appId], references: [id], onDelete: Cascade)
  path        String
  s3Key       String
  sizeBytes   Int      @default(0)
  contentType String   @default("text/plain")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([appId, path])
}

model MiniAppStorage {
  id        String   @id @default(cuid())
  appId     String
  app       MiniApp  @relation(fields: [appId], references: [id], onDelete: Cascade)
  key       String
  value     Json
  updatedAt DateTime @updatedAt

  @@unique([appId, key])
  @@index([appId])
}

model MiniAppSnapshot {
  id           String   @id @default(cuid())
  appId        String
  app          MiniApp  @relation(fields: [appId], references: [id], onDelete: Cascade)
  version      Int
  label        String?
  fileManifest Json
  createdAt    DateTime @default(now())

  @@index([appId])
}
