# =============================================================================
# ModularMind V2 — Environment Variables
# =============================================================================
# Copy to .env and fill in values

# --- Database ---
DB_USER=modularmind
DB_PASSWORD=change-me-in-production

# --- Engine ---
SECRET_KEY=generate-with-openssl-rand-base64-32

# --- Platform connection (optional) ---
PLATFORM_URL=http://platform.example.com
ENGINE_API_KEY=mmk_your-engine-api-key-here

# --- Ports ---
HTTP_PORT=80
HTTPS_PORT=443
