# =============================================================================
# ModularMind V2 — Client Deployment Environment
# =============================================================================
# Copy to .env and fill in values. The install.sh script generates this
# automatically with random secrets.
#
# Docs: https://github.com/tipaq/ModularMind-V2

# --- Docker Compose Profiles ---------------------------------------------------
# Comma-separated list of active profiles.
# Available: proxy, ollama, gpu, gateway, storage, monitoring
#
#   proxy      - Internal Nginx on single port (recommended, see PROXY_PORT)
#   ollama     - Ollama LLM runtime (CPU mode)
#   gpu        - Ollama with NVIDIA GPU acceleration (use instead of 'ollama')
#   gateway    - Secure tool execution sandbox for agents
#   storage    - Built-in MinIO S3 (skip if using external S3)
#   monitoring - Prometheus + Grafana dashboards
#
COMPOSE_PROFILES=proxy,ollama,storage

# --- Image Version -------------------------------------------------------------
# Pin to a specific release tag or use 'latest'.
MM_VERSION=latest

# --- Database ------------------------------------------------------------------
DB_USER=modularmind
DB_PASSWORD=                      # REQUIRED — generate: openssl rand -base64 24

# --- Engine Secrets ------------------------------------------------------------
SECRET_KEY=                       # REQUIRED — generate: openssl rand -base64 32

# --- Platform Connection -------------------------------------------------------
# Connect this engine to your ModularMind Platform for config sync.
# Leave empty to run standalone (no sync).
PLATFORM_URL=                     # e.g., https://platform.modularmind.dev
ENGINE_API_KEY=                   # e.g., mmk_abc123... (from Platform admin)

# --- Proxy (profile: proxy) ---------------------------------------------------
# Port the built-in Nginx listens on. Your external reverse proxy (Traefik,
# Caddy, etc.) should route to this port.
PROXY_PORT=8080

# --- Engine Direct Access ------------------------------------------------------
# When NOT using the proxy profile, this controls engine port exposure.
# Default: localhost only (safe). Change to 0.0.0.0:8000:8000 for external.
ENGINE_PORT=127.0.0.1:8000:8000

# --- S3 / Object Storage (profile: storage) -----------------------------------
# With the 'storage' profile, a built-in MinIO handles S3.
# For external S3 (AWS, Cloudflare R2, etc.): remove 'storage' profile and
# set these to your provider's values.
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=modularmind
S3_SECRET_KEY=                    # REQUIRED — generate: openssl rand -base64 24

# --- Ollama (profile: ollama or gpu) ------------------------------------------
# CPU mode: http://ollama:11434
# GPU mode: http://ollama-gpu:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_KEEP_ALIVE=24h

# --- Gateway (profile: gateway) -----------------------------------------------
GATEWAY_ENABLED=false

# --- Monitoring (profile: monitoring) -----------------------------------------
GRAFANA_PASSWORD=modularmind
GRAFANA_PORT=3333
