# MCP Brave Search Sidecar
# Extends mcp-proxy with Node.js to run @anthropic/brave-search-mcp
#
# The mcp-proxy image is Alpine-based (Python) and wraps stdio MCP servers
# as HTTP/SSE endpoints. The Brave Search MCP server requires Node.js.

FROM ghcr.io/sparfenyuk/mcp-proxy:latest

USER root

# Install Node.js (required for npx / @anthropic/brave-search-mcp)
RUN apk add --no-cache nodejs npm

# Reset to non-root user for security
USER nobody
