# MCP DuckDuckGo Search Sidecar
# Extends mcp-proxy with duckduckgo-mcp-server (Python).
# No API key required — completely free web search.

FROM ghcr.io/sparfenyuk/mcp-proxy:latest

USER root

# Install pip into the venv, then install DuckDuckGo MCP server
RUN /app/.venv/bin/python -m ensurepip && \
    /app/.venv/bin/python -m pip install --no-cache-dir duckduckgo-mcp-server

# Reset to non-root user for security
USER nobody
